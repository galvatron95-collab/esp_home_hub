# values, and never commit the filled copy. See CLAUDE.md §3.
#
# Generate api_encryption_key per ESPHome docs:
#   https://esphome.io/components/api.html
# Generate ota_password as any sufficiently random string.

wifi_ssid: REPLACE_ME
wifi_password: REPLACE_ME
api_encryption_key: REPLACE_ME_BASE64
ota_password: REPLACE_ME
