/*
 * secrets.h.example — WiFi credentials template.
 *
 * Setup:
 *   1. Copy this file to main/secrets.h
 *      (cp main/secrets.h.example main/secrets.h)
 *   2. Replace the placeholder values with your real WiFi
 *      credentials.
 *   3. Build. main/secrets.h is gitignored.
 *
 * Per CLAUDE.md §3.2:
 *   - main/secrets.h is never committed.
 *   - Its values are never logged or otherwise disclosed,
 *     including partial disclosure (length, prefix, redacted-
 *     but-shaped placeholders).
 *   - Only files that consume a secret may #include it.
 */
#pragma once

#define WIFI_SSID      "REPLACE_ME_SSID"
#define WIFI_PASSWORD  "REPLACE_ME_PASSWORD"
